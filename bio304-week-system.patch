+.ch{display:flex;width:100%;align-items:baseline;gap:12px;text-align:left;background:none;border:0;border-radius:8px;padding:10px 12px;cursor:pointer;font-family:inherit;color:#0B1530;transition:background .15s ease}
+.ch:hover{background:#EDF1F3}
