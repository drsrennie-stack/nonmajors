+  <p class="lead">Watch the full walkthrough, or jump to a chapter once the video is posted.</p>
+</section>
+<main class="layout pad">
+  <div class="frame" id="video">
+    <iframe id="player"
+      title="Hormone Mechanisms concept video"
+      allow="autoplay; fullscreen; picture-in-picture"
+      allowfullscreen></iframe>
+    <div class="frame-empty" id="frame-empty" hidden>This video will be posted here. Check back soon.</div>
