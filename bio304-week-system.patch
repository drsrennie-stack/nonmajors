+.frame{position:relative;aspect-ratio:16/9;background:#000;border-radius:12px;overflow:hidden;border:1px solid #8C90A0}
+.frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
+.frame-empty{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;text-align:center;padding:24px;background:#0B1530;color:#F5F1E8;font-size:16px;font-weight:600;line-height:1.5}
