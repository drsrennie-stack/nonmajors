+/* INSTRUCTOR: set LOOM_ID to the part after /embed/ in the Loom share URL.
+   Leave it empty ("") to show the "coming soon" placeholder.
+   Chapter times are seconds, set with data-s on each button. */
+(function(){
+  var LOOM_ID = "";
+  var EXTRA = "hide_owner=true&hideEmbedTopBar=true";
+  var BASE = "https://www.loom.com/embed/" + LOOM_ID;
+  var player = document.getElementById("player");
+  var empty = document.getElementById("frame-empty");
+  var buttons = Array.prototype.slice.call(document.querySelectorAll(".ch"));
+  if(!LOOM_ID){ player.hidden = true; empty.hidden = false; return; }
+  player.src = BASE + "?" + EXTRA;
+  buttons.forEach(function(b){
+    b.addEventListener("click", function(){
+      var s = b.getAttribute("data-s");
+      player.src = BASE + "?" + EXTRA + "&t=" + s + "&autoplay=1";
+      buttons.forEach(function(x){ x.removeAttribute("aria-current"); });
+      b.setAttribute("aria-current","true");
+      document.getElementById("video").scrollIntoView({behavior:"smooth",block:"nearest"});
+    });
+  });
+})();
+(function(){function send(){try{parent.postMessage({type:'iframe-height',id:'bio304-action-potentials-synapses-video',height:document.documentElement.scrollHeight},'*');}catch(e){}}
+window.addEventListener('load',send);window.addEventListener('resize',send);
+if(window.ResizeObserver){new ResizeObserver(send).observe(document.body);}})();
+</script>
